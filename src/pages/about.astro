			</section>
		</main>
		<Footer />
		<CassettePlayer />

		<style>
			.eyebrow {
				font-size: 0.85em;
				color: var(--accent-dark);
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 0.5em;
			}
		</style>
	</body>
</html>
